# ─────────────────────────────────────────────────────────────────────────────
# MySQL deployment environment template
# ─────────────────────────────────────────────────────────────────────────────
#
# USAGE
#   1. Copy this file:  Copy-Item deployment\env.mysql.template deployment\.env.mysql
#   2. Fill in every value marked CHANGE_ME
#   3. NEVER commit .env.mysql — it is listed in .gitignore
#
# Run first-time deployment:
#   .\deployment\deploy_mysql.ps1
#
# Key rules:
#   - SECRET_KEY must be a random 32-byte hex string.
#     Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
#   - MYSQL_ROOT_PASSWORD is used ONLY inside the Docker container (root only).
#   - MYSQL_APP_PASSWORD is used by the backend application (limited-privilege user).
#   - ADMIN_PASSWORD must meet your organisation's password policy.
# ─────────────────────────────────────────────────────────────────────────────

# ── Host port mapping ────────────────────────────────────────────────────────

# Frontend exposed on the host.
FRONTEND_PORT=3000

# Backend API exposed on the host.
BACKEND_PORT=7999

# Internal uvicorn port inside the backend container (do not change unless you
# also update backend.Dockerfile CMD).
BACKEND_INTERNAL_PORT=8000

# MySQL host binding.
# Production:  127.0.0.1:3306  (loopback only — not reachable from outside host)
# Development: 3306             (all interfaces, convenient for local tools)
MYSQL_EXPOSED_PORT=127.0.0.1:3306

# ── Frontend ─────────────────────────────────────────────────────────────────

# API path the React bundle uses. Leave as /api unless you have a custom path.
FRONTEND_API_URL=/api

# Build type: prod | trial | sandbox
PACKAGE_OPTION=prod

# ── MySQL — database names ────────────────────────────────────────────────────

# Primary application database.
MYSQL_DATABASE=ecomdb_phase6

# Activity / audit log database.
LOG_DATABASE=ecomdb_phase6_log

# ── MySQL — root credentials ─────────────────────────────────────────────────
# Used only by the MySQL container itself (not exposed to the application).
# Store this in your secrets manager; do not share it with application teams.

MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# ── MySQL — application user ─────────────────────────────────────────────────
# A dedicated limited-privilege user created by mysql-init.sh at first boot.
# The backend connects with these credentials (GRANT ALL on both databases).

MYSQL_APP_USER=ecom_app
MYSQL_APP_PASSWORD=CHANGE_ME_app_password

# ── Backend application secrets ───────────────────────────────────────────────

# JWT / session signing key — must be unique per environment.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32

# Default admin account created on first startup by init_db.py.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_EMAIL=admin@yourdomain.com

# ── MSG91 OTP (SMS delivery) ──────────────────────────────────────────────────
# Required for user registration OTP in production.
# Obtain credentials from https://msg91.com/
# Leave blank to disable OTP sending in non-production environments.

MSG91_AUTHKEY=CHANGE_ME_msg91_authkey
MSG91_TEMPLATE_ID=CHANGE_ME_msg91_template_id
MSG91_SENDER_ID=AIESHP
