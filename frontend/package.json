{
  "name": "ecom-frontend",
  "version": "1.0.0",
  "description": "E-Commerce Frontend",
  "private": true,
  "dependencies": {
    "axios": "^1.6.0",
    "core-js": "^3.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "regenerator-runtime": "^0.14.1",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "playwright": "^1.59.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.3"
  },
  "scripts": {
    "start": "node ../test_suit/start-available-port.js",
    "build": "echo 'Usage: npx webpack --mode production --env packageOption=sandbox|trial|prod' && exit 1",
    "build:sandbox": "webpack --mode production --env packageOption=sandbox",
    "build:trial": "webpack --mode production --env packageOption=trial",
    "build:prod": "webpack --mode production --env packageOption=prod",
    "dev": "node ../test_suit/start-available-port.js",
    "test": "node ../test_suit/frontend/run_playwright_tests.js",
    "test:ui": "node ../test_suit/frontend/run_playwright_tests.js",
    "test:ui:headed": "playwright test -c ../test_suit/frontend/playwright.config.ts --headed",
    "test:ui:debug": "playwright test -c ../test_suit/frontend/playwright.config.ts --debug"
  }
}
